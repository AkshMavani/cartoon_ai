<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/gradient_primary"
                android:endColor="@color/gradient_secondary"
                android:angle="0"
                android:type="linear"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#35323d"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
