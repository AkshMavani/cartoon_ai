<?xml version="1.0" encoding="utf-8"?>
<com.skylock.ai_cartoon.square.SquareLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:layout_gravity="center"
    android:id="@+id/root"
    android:background="#202020"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/_5sdp">
    <LinearLayout
        android:paddingTop="@dimen/_7sdp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingEnd="@dimen/_7sdp">
        <com.skylock.ai_cartoon.square.SquareCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#202020"
            app:cardCornerRadius="@dimen/_8sdp"
            app:cardUseCompatPadding="false">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgItemPhotoLibrary"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </com.skylock.ai_cartoon.square.SquareCardView>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/itemDelete"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:layout_alignParentEnd="true">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="end"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_close_photo"/>
    </FrameLayout>
</com.skylock.ai_cartoon.square.SquareLayout>
