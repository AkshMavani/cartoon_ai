<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/main_primary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/llLibraryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusBar">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/imgBack"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/icon_medium"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/ic_back"/>
        </FrameLayout>
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:id="@+id/tvLibraryHeader"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:gravity="center"
            android:id="@+id/ivQuestion"
            android:layout_width="@dimen/icon_large"
            android:layout_height="@dimen/icon_large"
            app:srcCompat="@drawable/ic_message_question"/>
    </LinearLayout>
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/itemContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:layout_constraintBottom_toTopOf="@+id/pgLoadMore"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llLibraryHeader">
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:background="@color/main_primary"
            android:paddingBottom="@dimen/_6sdp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabGravity="start"
            app:tabSelectedTextColor="@color/white"
            app:tabTextColor="#929292"
            style="@style/TabLayoutStyle"/>
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/fakeItemMultiplePhoto"
            android:layout_below="@+id/tabLayout"
            android:paddingHorizontal="12dp"/>
        <View
            android:orientation="vertical"
            android:id="@+id/fakeItemMultiplePhoto"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/bottomMultiplePhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">
            <LinearLayout
                android:gravity="end|center_vertical"
                android:layout_gravity="end|center_vertical"
                android:orientation="vertical"
                android:id="@+id/flMultiple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_15sdp">
                <com.skylock.ai_cartoon.textview.TextViewApp
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:gravity="top|center_horizontal"
                    android:id="@+id/tvEditInBulk"
                    android:background="@drawable/bg_select_to_edit_in_bulk"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_select_to_edit_in_bulk"
                    android:includeFontPadding="false"
                    android:paddingVertical="8dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/itemMultiple"
                    android:background="@drawable/bg_button_multi_enhancing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <androidx.appcompat.widget.AppCompatImageView
                        android:gravity="center"
                        android:id="@+id/btnCamera"
                        android:layout_width="@dimen/icon_large"
                        android:layout_height="@dimen/icon_large"
                        android:layout_marginStart="12dp"
                        app:srcCompat="@drawable/ic_dark"/>
                    <com.skylock.ai_cartoon.textview.TextViewApp
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:id="@+id/tvMultiple"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_multi_enhancing"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="8dp"
                        android:layout_marginVertical="10dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/itemMultiplePhoto"
                android:background="@drawable/bg_border_bottom_recommend"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/applyAnimation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp">
                    <com.skylock.ai_cartoon.textview.TextViewApp
                        android:textSize="10sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_apply_multiple_photo"
                        android:includeFontPadding="false"
                        android:drawablePadding="@dimen/_5sdp"
                        android:layout_weight="1"
                        android:drawableStart="@drawable/ic_lock"
                        android:paddingVertical="@dimen/_10sdp"/>
                    <com.skylock.ai_cartoon.textview.TextViewApp
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:id="@+id/tvMultiplePro"
                        android:background="@drawable/bg_button_gradient_15"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_go_pro"
                        android:paddingHorizontal="@dimen/_15sdp"
                        android:paddingVertical="@dimen/_5sdp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvChoosePhotos"
                    android:padding="@dimen/_5sdp"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_120sdp"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_15sdp">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.skylock.ai_cartoon.textview.TextViewApp
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_please_choose_photos"
                            android:includeFontPadding="false"
                            android:paddingVertical="@dimen/_10sdp"/>
                        <com.skylock.ai_cartoon.textview.TextViewApp
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/main_primary"
                            android:gravity="center"
                            android:id="@+id/tvMultipleImport"
                            android:background="@drawable/bg_select_photos"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:text="5"
                            android:includeFontPadding="false"
                            android:layout_marginStart="@dimen/_10sdp"/>
                    </LinearLayout>
                    <com.skylock.ai_cartoon.textview.TextViewApp
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:id="@+id/tvCancelMultiple"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cancel_down_case"
                        android:includeFontPadding="false"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
    <ProgressBar
        android:id="@+id/pgLoadMore"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:indeterminateTint="@color/button_primary"
        app:layout_constraintBottom_toTopOf="@+id/adViewContainer"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/itemContent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/llCategoryContent"
        android:background="#af000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llLibraryHeader">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategory"
            android:background="@color/main_primary"
            android:paddingBottom="8dp"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="400dp"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/llLoadingPhoto"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/adViewContainer"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llLibraryHeader">
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loading_processing"/>
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:gravity="center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/preparing_photos"
            style="@style/text_primary"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/llMultiple"
        android:background="@drawable/bg_import_multi"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingStart="12dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintBottom_toTopOf="@+id/adViewContainer"
        app:layout_constraintEnd_toEndOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/imgMultiplePro"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="4dp"
            app:srcCompat="@drawable/ic_premium"/>
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@+id/btnProcessMultiple"
            android:background="@drawable/bg_round_white"
            android:padding="12dp"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="4dp">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleX="-1"
                android:layout_marginStart="4dp"
                app:srcCompat="@drawable/ic_prev"
                app:tint="@color/text_secondary"/>
        </FrameLayout>
    </LinearLayout>
    <include
        android:id="@+id/deny_permission"
        android:layout_width="match_parent"
        android:layout_height="0dp"

        app:layout_constraintBottom_toTopOf="@+id/adViewContainer"
        app:layout_constraintTop_toBottomOf="@+id/llLibraryHeader"
        layout="@layout/layout_deny_permission"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="deny_permission"/>
    <FrameLayout
        android:gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/adViewContainer"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:id="@+id/tvLoadingAd"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
