<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/main_primary"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/statusBar"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"/>
    <RelativeLayout
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:paddingHorizontal="16dp">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/imgBack"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_centerVertical="true">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/icon_small"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/ic_back"/>
        </FrameLayout>
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/crop_title"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="@dimen/_1sdp"
            style="@style/text_header_medium"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/btnGender"
            android:background="@drawable/bg_gender_female"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_8sdp">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgGender"
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_12sdp"
                android:src="@drawable/ic_female"/>
            <com.skylock.ai_cartoon.textview.TextViewApp
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:id="@+id/tvGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/female"
                android:layout_marginHorizontal="@dimen/_1sdp"
                style="@style/text_header_medium"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_9sdp"
                android:layout_height="@dimen/_9sdp"
                android:src="@drawable/ic_arrow_down"
                android:layout_marginStart="@dimen/_1sdp"
                app:tint="#e0ffffff"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <com.skylock.ai_cartoon.crop.ImageCropView
                android:id="@+id/imageCropView"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:gridInnerColor="#66ffffff"
                app:gridInnerStroke="1.5dp"
                app:gridOuterColor="#ffffff"
                app:gridOuterStroke="1.5dp"
                app:outsideLayerColor="#99000000"
                app:setInnerGridMode="on"
                app:setOuterGridMode="on"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/loading"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/white"/>
        </FrameLayout>
        <include
            android:id="@+id/bottomCrop"
            layout="@layout/item_bottom_control_crop_image"/>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
