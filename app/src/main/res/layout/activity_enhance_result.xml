<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_primary"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <FrameLayout
                android:id="@+id/imgBack"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/icon_medium"
                    android:layout_height="match_parent"
                    app:srcCompat="@drawable/ic_back" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvResultHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/result"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:visibility="visible"
                app:fontWeight="600" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgFeedback"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_feedback" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnSave"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:padding="@dimen/_6sdp"
                android:src="@drawable/ic_download" />
        </RelativeLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/_5sdp">

            <TextView
                android:id="@+id/btnVersion3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:background="@drawable/bg_header_button_version_2"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/label_upscale_x3"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:fontWeight="600" />

            <com.skylock.ai_cartoon.textview.TextViewApp
                android:id="@+id/tvHeaderPro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:background="@drawable/bg_pro"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="@string/label_pro"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="visible" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/llPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_gravity="center"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="4"
            android:gravity="center">

            <FrameLayout
                android:id="@+id/flPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginHorizontal="@dimen/_12sdp">
                <!--
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    app:cardCornerRadius="15dp"
                                    app:cardElevation="0dp"
                                    app:cardUseCompatPadding="false">-->

                <com.skylock.ai_cartoon.enhance.ImageBeforeAfterSlider
                    android:id="@+id/ibasPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:visibility="visible"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:image_before_disable_zoom="false">

                    <RelativeLayout
                        android:id="@+id/itemShowCase"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#99000000"
                        android:orientation="vertical"
                        android:visibility="invisible">

                        <LinearLayout
                            android:id="@+id/showCaseResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/_40sdp"
                                android:gravity="center"
                                android:text="@string/label_show_case_result"
                                android:textColor="@color/white"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/continueShowCase"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="@dimen/_20sdp"
                                android:background="@drawable/bg_button_continue"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/_15sdp"
                                android:paddingVertical="@dimen/_10sdp"
                                android:text="@string/label_continue"
                                android:textColor="@color/white"
                                android:textSize="16sp" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:src="@drawable/bg_show_case_result" />
                        </LinearLayout>
                    </RelativeLayout>
                </com.skylock.ai_cartoon.enhance.ImageBeforeAfterSlider>
                <!--                </com.google.android.material.card.MaterialCardView>-->
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCallToAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:text="@string/label_result_call_to_action"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/_16sdp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_border_bottom_recommend"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llBottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="bottom"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/llRecycelview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/btnGenerate"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_gen_beauty_plus" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal"
                        android:visibility="visible"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                </LinearLayout>


                <RelativeLayout
                    android:id="@+id/layoutTickClose"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:paddingHorizontal="@dimen/_10sdp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/itemResultClose"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        app:srcCompat="@drawable/ic_result_close" />

                    <com.skylock.ai_cartoon.textview.TextViewApp
                        android:id="@+id/tvBottomFeature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:gravity="center"
                        android:text="@string/enhance"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:visibility="visible" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/itemResultSaveChange"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_alignParentEnd="true"
                        app:srcCompat="@drawable/ic_result_save_change" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/btnFace"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_secondary"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="6dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="wrap_content"
                            android:rotation="180"
                            android:src="@drawable/ic_down" />

                        <com.skylock.ai_cartoon.textview.TextViewApp
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="0dp"
                            android:text="@string/face"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_secondary"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:layout_marginHorizontal="6dp"
                            android:src="@drawable/ic_download"
                            app:tint="@color/white" />

                        <com.skylock.ai_cartoon.textview.TextViewApp
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/save_all"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <include
                    android:id="@+id/moreTool"
                    layout="@layout/layout_aitool_expand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/adViewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <com.skylock.ai_cartoon.textview.TextViewApp
                    android:id="@+id/tvLoadingAds"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:textColor="@color/text_primary" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/flFakeNavigation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#333333"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <include
        android:id="@+id/showCase"
        layout="@layout/toot_tip_show_beauty_result"
        android:visibility="gone" />
</androidx.constraintlayout.widget.ConstraintLayout>
