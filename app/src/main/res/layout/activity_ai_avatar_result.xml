<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/viewAdd"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/linearLayout"
        android:background="@color/main_primary"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:paddingHorizontal="16dp">
            <FrameLayout
                android:layout_gravity="center_vertical"
                android:id="@+id/imgBack"
                android:layout_width="32dp"
                android:layout_height="match_parent">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/icon_medium"
                    android:layout_height="match_parent"
                    app:srcCompat="@drawable/ic_back"/>
            </FrameLayout>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgChangePhoto"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_8sdp"
                app:srcCompat="@drawable/ic_change_photo"/>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <com.skylock.ai_cartoon.textview.TextViewApp
                android:textSize="@dimen/text_header"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:id="@+id/btn_premium"
                android:background="@drawable/bg_button_gradient_45"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pro"
                android:drawablePadding="5dp"
                android:drawableStart="@drawable/ic_star_generate"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:gravity="center"
                android:id="@+id/btnSave"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_download"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/llPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:layout_marginHorizontal="4dp">
            <FrameLayout
                android:id="@+id/flPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/imgBefore"
                    android:background="@color/black"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:riv_corner_radius="24dp"
                    app:riv_mutate_background="true"/>
                <FrameLayout
                    android:id="@+id/download_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.makeramen.roundedimageview.RoundedImageView
                        android:id="@+id/imgAfter"
                        android:background="@color/black"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:riv_corner_radius="24dp"
                        app:riv_mutate_background="true"/>
                    <include
                        android:id="@+id/water_mask"
                        layout="@layout/view_water_mask"/>
                </FrameLayout>
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="bottom|left"
                    android:id="@+id/imgBeautifier"
                    android:background="@drawable/bg_icon_primary"
                    android:padding="6dp"
                    android:visibility="visible"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_face_retouching"
                    app:tint="@color/white"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="bottom|right"
                    android:id="@+id/imgFlipback"
                    android:background="@drawable/bg_icon_primary"
                    android:padding="8dp"
                    android:visibility="visible"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_flipback"/>
            </FrameLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="bottom"
            android:orientation="vertical"
            android:id="@+id/llMainTool2"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:layout_marginVertical="@dimen/_12sdp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnGenerate"
                    android:background="@drawable/bg_icon_secondary"
                    android:layout_width="@dimen/_46sdp"
                    android:layout_height="@dimen/_46sdp"
                    android:src="@drawable/ic_re_generate"
                    android:paddingHorizontal="14dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:orientation="horizontal"
                    android:id="@+id/rvResult"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_6sdp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/bottomCategory"
                android:background="@drawable/bg_bottom_sheet"
                android:paddingTop="@dimen/_12sdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:orientation="horizontal"
                    android:id="@+id/rvCategory"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingStart="12dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:orientation="horizontal"
                    android:id="@+id/rvCartoonStyle"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <include
        android:id="@+id/toolTipResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        layout="@layout/toot_tip_show_ai_result"/>
</androidx.constraintlayout.widget.ConstraintLayout>
