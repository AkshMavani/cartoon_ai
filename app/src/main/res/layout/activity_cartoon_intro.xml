<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:background="@color/main_primary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.skylock.ai_cartoon.cropvideoview.CropVideoView
        android:id="@+id/video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:translationZ="99dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusBar">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/imgBack"
            android:layout_width="32dp"
            android:layout_height="match_parent">
            <ImageView
                android:layout_width="@dimen/icon_medium"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/ic_back"/>
        </FrameLayout>
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center_horizontal"
            android:id="@+id/tvResultHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_bottom_aiavatar_intro"
        android:paddingTop="60dp"
        android:paddingBottom="16dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:translationZ="99dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">
            <com.skylock.ai_cartoon.textview.TextViewApp
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Turn Your Photos Into Beautiful Art"
                android:layout_marginVertical="4dp"
                style="@style/text_primary"/>
            <com.skylock.ai_cartoon.textview.GradientTextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_filter"
                android:layout_marginStart="4dp"
                android:layout_marginVertical="4dp"
                style="@style/text_primary"/>
        </LinearLayout>
        <com.skylock.ai_cartoon.textview.TextViewApp
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:id="@+id/btnSelectPhoto"
            android:background="@drawable/bg_button_secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/select_photo"
            android:drawableEnd="@drawable/ic_next_black"
            android:paddingHorizontal="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
